# Application identity and runtime network binding
APP_NAME=execo-rag
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# Logging controls
LOG_LEVEL=INFO
LOG_JSON=true
LOG_FORMAT=json

# Optional OpenRouter settings for metadata fallback and remote embeddings
OPENROUTER_API_KEY=replace_me
OPENROUTER_CHAT_MODEL=meta-llama/llama-3-8b-instruct:free

# Embedding configuration
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32
# To route embeddings through OpenRouter instead:
# EMBEDDING_PROVIDER=openrouter
# EMBEDDING_MODEL=text-embedding-3-small

# Pinecone credentials and target namespace
# Create the Pinecone index with the same EMBEDDING_DIMENSION value.
PINECONE_API_KEY=replace_me
PINECONE_INDEX_NAME=replace_me
PINECONE_NAMESPACE=contracts-dev

# PDF extraction and chunk sizing
PDF_EXTRACTOR=unstructured
MAX_CHUNK_TOKENS=700
CHUNK_OVERLAP_TOKENS=60

# Runtime flags
RUNTIME_DEBUG=false
RUNTIME_RELOAD=false
ENABLE_LLM_FALLBACK=true
ENABLE_METRICS=false
